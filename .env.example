# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored — never commit real secrets.

NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/prajaakeya
JWT_SECRET=replace-with-a-long-random-secret

AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET_NAME=prajaakeeya
AWS_REGION=ap-south-1

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_FRONTEND_REDIRECT_URI=http://localhost:5173/oauth/success

CORS_ALLOWED_ORIGINS_PROD=https://prajaakeeya.org,https://www.prajaakeeya.org
CORS_ALLOWED_ORIGINS_DEV=http://localhost:5173,https://staging.prajaakeeya.org
# Local web-push testing — path to the Firebase service-account JSON on disk.
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-adminsdk.json

# Sentry error tracking (leave unset to disable)
#SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
